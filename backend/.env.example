# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL=postgresql://mailplatform:YOUR_DB_PASSWORD@localhost:5432/emailplatform

# Redis
REDIS_URL=redis://localhost:6379

# JWT (min 32 chars, use a random string)
JWT_SECRET=CHANGE-THIS-generate-with-openssl-rand-hex-32

# JWT Token Expiry
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Platform
PLATFORM_DOMAIN=mail.yourdomain.com

# Encryption key for DKIM keys at rest (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=CHANGE-THIS-generate-with-openssl-rand-hex-32
